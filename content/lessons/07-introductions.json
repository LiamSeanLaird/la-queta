{
  "id": "introductions",
  "title": "Introductions",
  "order": 7,
  "summary": "Say who you are, where you’re from, and exchange basic personal details.",
  "sections": [
    {
      "type": "text",
      "content": "At A1 you need a small set of ready-made phrases for meeting people: greeting, giving your name, saying where you live or come from, and asking the same of others."
    },
    {
      "type": "rule",
      "content": "Use Em dic… for ‘My name is…’ and Soc de… for origin. Com et dius? asks someone’s name (informal)."
    },
    {
      "type": "examples",
      "items": [
        {
          "catalan": "Hola, em dic Liam.",
          "english": "Hi, my name is Liam.",
          "note": ""
        },
        {
          "catalan": "Soc d’Irlanda.",
          "english": "I’m from Ireland.",
          "note": "de + vowel → d’"
        },
        {
          "catalan": "Visc a Barcelona.",
          "english": "I live in Barcelona.",
          "note": ""
        },
        {
          "catalan": "Encantat / Encantada.",
          "english": "Nice to meet you.",
          "note": "m / f"
        }
      ]
    },
    {
      "type": "rule",
      "content": "Keep answers short. At A1, clear stock phrases beat long sentences."
    }
  ],
  "practice": [
    {
      "id": "in-p01",
      "kind": "multiple_choice",
      "question": "How do you say ‘My name is…’?",
      "options": [
        "Em dic…",
        "Em dius…",
        "Soc dic…"
      ],
      "answer": "Em dic…",
      "explanation": "Em dic + name."
    },
    {
      "id": "in-p02",
      "kind": "multiple_choice",
      "question": "How do you ask ‘What’s your name?’ (informal)?",
      "options": [
        "Com et dius?",
