{
  "id": "food-cafe",
  "title": "Food & Café",
  "order": 8,
  "summary": "Order a drink or snack and understand simple café language.",
  "sections": [
    {
      "type": "text",
      "content": "Café and bar Spanish/Catalan life is core A1: asking for things politely, naming drinks and food, and understanding prices or ‘here you are’."
    },
    {
      "type": "rule",
      "content": "Vull… / Em posa… / Un cafè, si us plau. Use si us plau for please; gràcies for thanks."
    },
    {
      "type": "examples",
      "items": [
        {
          "catalan": "Un cafè amb llet, si us plau.",
          "english": "A coffee with milk, please.",
          "note": ""
        },
        {
          "catalan": "Què vol beure?",
          "english": "What would you like to drink?",
          "note": "waiter → customer"
        },
        {
          "catalan": "El compte, si us plau.",
          "english": "The bill, please.",
          "note": ""
        },
        {
          "catalan": "Quant val?",
          "english": "How much is it?",
          "note": ""
        }
      ]
    }
  ],
